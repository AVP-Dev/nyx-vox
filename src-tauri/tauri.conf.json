{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NYX Vox",
  "version": "1.0.0",
  "identifier": "com.nyx.vox2",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3002",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "NYX Vox",
        "width": 150,
        "height": 48,
        "minWidth": 64,
        "minHeight": 48,
        "maxWidth": 800,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https://api.github.com https://api.deepgram.com https://api.groq.com https://generativelanguage.googleapis.com https://api.deepseek.com https://dashscope.aliyuncs.com; media-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.mac.plist"
    }
  }
}
